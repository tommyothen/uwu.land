{
  "name": "uwu-land-api",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-01",
  "kv_namespaces": [
    { "binding": "UWU", "id": "TODO-kv-id-uwu" },
    { "binding": "CLICKS", "id": "TODO-kv-id-clicks" }
  ],
  "analytics_engine_datasets": [
    { "binding": "CLICK_EVENTS", "dataset": "TODO-ae-dataset" }
  ],
  // Refresh the add-only grabber-domain blocklist daily at 06:00 UTC.
  "triggers": {
    "crons": ["0 6 * * *"]
  },
  // Set CLERK_WEBHOOK_SIGNING_SECRET with `wrangler secret put`; do not add it to vars.
  "vars": {
    "CLERK_ISSUER": "TODO-clerk-issuer"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "uwu-land",
      "database_id": "TODO-d1-id",
      "migrations_dir": "../../packages/db/migrations"
    }
  ]
}
