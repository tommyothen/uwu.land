# Copy to `.env.local` for local development (Vite reads .env.local, NOT .dev.vars).
# These are documented placeholders — replace with your Clerk app's real keys.

# Clerk publishable key (public). Dummy value = base64("clerk.example.com$").
VITE_CLERK_PUBLISHABLE_KEY=pk_test_Y2xlcmsuZXhhbXBsZS5jb20k

# Clerk secret key (server-side only, never exposed to the browser).
CLERK_SECRET_KEY=sk_test_placeholder

# Base URL of the uwu.land worker API. Defaults to https://uwu.land when unset.
VITE_UWU_API_URL=http://localhost:8787
