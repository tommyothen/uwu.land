{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "VITE_CLERK_PUBLISHABLE_KEY",
        "VITE_UWU_API_URL",
        "CLERK_SECRET_KEY"
      ],
      "outputs": [
        "build/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "test": {},
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    }
  }
}
